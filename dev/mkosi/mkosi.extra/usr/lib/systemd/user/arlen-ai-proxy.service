[Unit]
Description=Arlen AI egress proxy (the completion authoriser, user service)
Documentation=https://github.com/arlenos/arlen
# The single egress point for AI provider traffic: ai-daemon forwards completions
# here over the session bus, the proxy looks up the catalogued endpoint (the local
# llama-server) and forwards. Audits each forward, so order it after auditd
# (best-effort, not a hard Requires).
After=arlen-auditd.service
Wants=arlen-auditd.service

[Service]
Type=simple
ExecStart=/usr/lib/arlen/libexec/arlen-ai-proxy
Restart=on-failure
RestartSec=2

# It talks the session D-Bus (AF_UNIX) and forwards HTTP to the local llama-server
# on 127.0.0.1:11434 (AF_INET). In this image the ONLY provider is local, so lock
# egress to loopback - the zero-egress posture (a product image with cloud
# providers would relax IPAddressAllow).
#
# It authorises each forward by resolving the caller's /proc/<pid>/exe against
# its caller allowlist, so it must NOT use mount-namespace hardening (ProtectSystem,
# ProtectHome, PrivateTmp, ProtectKernel*, ProtectControlGroups): those make a
# same-uid /proc/<pid>/exe read fail, which would reject every forward. The
# non-namespace hardening is kept - and egress is still locked to loopback at the
# packet level via the IP filter (eBPF, not a mount namespace), which is the
# property that actually matters for an egress proxy.
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
IPAddressAllow=localhost
IPAddressDeny=any
RestrictNamespaces=yes
LockPersonality=yes
NoNewPrivileges=yes

[Install]
WantedBy=default.target
