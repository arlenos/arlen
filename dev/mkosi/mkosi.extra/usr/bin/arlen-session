#!/bin/sh
# The Arlen graphical session, launched by greetd `[initial_session]` as the
# `arlen` user inside a logind/PAM session (so XDG_RUNTIME_DIR/XDG_SEAT exist).
#
# The system daemons (event-bus, knowledge, audit, ...) are systemd SYSTEM
# services already up at multi-user.target, binding their sockets under
# /run/arlen (a system service has no XDG_RUNTIME_DIR, so os_sdk's socket
# resolver lands there). This script starts only the GRAPHICAL layer and points
# the user-session clients at those system sockets.
#
# Sequence (the plan's Phase-2 glue): export the env -> launch cosmic-comp, which
# auto-allocates its Wayland socket and on init imports WAYLAND_DISPLAY/DISPLAY
# into the systemd --user + D-Bus activation environment and sd_notify's READY
# (compositor src/systemd.rs + src/dbus/mod.rs) -> wait for that socket -> import
# the Arlen env into the --user manager so the shell/app user services inherit it
# -> start graphical-session.target -> wait on the compositor (its exit ends the
# session).
set -eu

# Point the user-session clients (shell, apps) at the SYSTEM daemon sockets under
# /run/arlen. os_sdk's resolver honours these ARLEN_*_SOCKET overrides first,
# ahead of its XDG_RUNTIME_DIR default - so a user-session client (which DOES have
# XDG_RUNTIME_DIR) still reaches the system daemons.
export ARLEN_PRODUCER_SOCKET=/run/arlen/event-bus-producer.sock
export ARLEN_CONSUMER_SOCKET=/run/arlen/event-bus-consumer.sock
export ARLEN_KNOWLEDGE_SOCKET=/run/arlen/knowledge.sock

# cosmic-comp auto-selects its backend: if DISPLAY or WAYLAND_DISPLAY is set it
# goes NESTED (x11/winit, for running inside another session); otherwise it uses
# the udev/KMS bare-metal backend that drives the seat's DRM device directly -
# which is what we want here. So those MUST be unset (a set-but-empty DISPLAY=
# makes cosmic-comp try X11 and fail). The software-GL stack: the VM's plain
# virtio-gpu has no hardware GL, so Mesa runs on llvmpipe and WebKitGTK must avoid
# the GPU/dmabuf compositing path (else the Tauri apps paint black). Harmless on
# real hardware; the image is the system-under-test.
unset DISPLAY WAYLAND_DISPLAY
export XDG_CURRENT_DESKTOP=arlen
export LIBGL_ALWAYS_SOFTWARE=1
export GALLIUM_DRIVER=llvmpipe
export GDK_BACKEND=wayland
export WEBKIT_DISABLE_COMPOSITING_MODE=1
export WEBKIT_DISABLE_DMABUF_RENDERER=1

# Launch the compositor in the background so we can start the user session once it
# is up. It imports WAYLAND_DISPLAY/DISPLAY itself; we add the Arlen env below.
systemd-cat -t cosmic-comp cosmic-comp &
compositor_pid=$!

# Wait for the compositor to publish its Wayland socket and capture its name into
# WAYLAND_DISPLAY (so the shell can connect). ~10s budget.
wl=
i=0
while [ "$i" -lt 100 ]; do
    for sock in "${XDG_RUNTIME_DIR}"/wayland-*; do
        case "$sock" in *.lock) continue;; esac
        [ -S "$sock" ] && { wl=$(basename "$sock"); break 2; }
    done
    i=$((i + 1))
    sleep 0.1
done
[ -n "$wl" ] && export WAYLAND_DISPLAY="$wl"

# Make the env visible to any systemd --user services too (best-effort).
systemctl --user import-environment \
    WAYLAND_DISPLAY XDG_CURRENT_DESKTOP \
    ARLEN_PRODUCER_SOCKET ARLEN_CONSUMER_SOCKET ARLEN_KNOWLEDGE_SOCKET \
    LIBGL_ALWAYS_SOFTWARE GALLIUM_DRIVER GDK_BACKEND \
    WEBKIT_DISABLE_COMPOSITING_MODE WEBKIT_DISABLE_DMABUF_RENDERER || true

# Launch the shell directly (not via a --user unit): simpler for this appliance,
# and systemd-cat routes its output to the system journal -> serial so the shell
# is diagnosable headlessly (a --user unit's journal is not forwarded). It
# connects to the compositor via WAYLAND_DISPLAY captured above.
if [ -n "$wl" ]; then
    systemd-cat -t arlen-shell arlen-desktop-shell &
fi

# Keep the session alive; when the compositor exits, the session ends and greetd
# returns to the greeter (or, for [initial_session], the VT).
wait "$compositor_pid"
