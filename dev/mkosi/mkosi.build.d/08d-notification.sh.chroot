#!/bin/sh
# Phase 8d (CHROOT): the notification daemon (arlen-notifyd). It owns the
# freedesktop `org.freedesktop.Notifications` D-Bus name (apps raise notifications)
# and serves the shell over `$XDG_RUNTIME_DIR/arlen/notification.sock` (the shell's
# notification client connects there to render toasts + the panel). Without it the
# shell's notification surface is dead in the image - the exact "backend built, not
# deployed" class as the consent broker. Packaged like the other libexec daemons.
#
# Its own standalone cargo workspace (daemons/notification-daemon) -> its own target
# dir in the persistent cache. Pure Rust, no C/C++.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-notification"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$CARGO_TARGET_DIR"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the notification daemon (arlen-notifyd) - Debian-native ($(cargo --version))"
cargo build --release --manifest-path daemons/notification-daemon/Cargo.toml

install -Dm755 "$CARGO_TARGET_DIR/release/arlen-notifyd" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-notifyd"
echo ">> staged arlen-notifyd into the image"
