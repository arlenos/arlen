#!/bin/sh
# Phase 8 (CHROOT): the audit daemon (arlen-auditd). The ai-agent's gate audits
# every decision BEFORE acting and fails CLOSED if the ledger is unreachable, so
# the in-VM dogfood's gate/approve/undo path needs auditd running. Built like the
# other Debian-native daemons; sqlx's bundled libsqlite3-sys compiles with the
# image's C toolchain (phase 1). Its own standalone cargo workspace -> its own
# target dir in the persistent cache.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-audit"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$CARGO_TARGET_DIR"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the audit daemon (arlen-auditd) - Debian-native ($(cargo --version))"
cargo build --release --manifest-path daemons/audit-daemon/Cargo.toml

# Its dist unit's ExecStart is /usr/lib/arlen/libexec/arlen-auditd.
install -Dm755 "$CARGO_TARGET_DIR/release/arlen-auditd" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-auditd"
echo ">> staged arlen-auditd into the image"
