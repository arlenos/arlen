#!/bin/sh
# Phase 8b (CHROOT): the config broker (arlen-config-broker), the separate-uid
# owner of the AI master switches (executor_live / access_level / enabled /
# provider / action_mode / autonomous_apps). It runs as root and owns a store
# the session user's uid cannot write, so a same-uid process can no longer flip
# those switches by rewriting ai.toml (same-uid-isolation-plan.md Tier-A #1).
# The AI daemon + agent read the switches from it and Settings writes through
# it; they tolerate a not-yet-running broker by falling back to ai.toml.
#
# Its own standalone cargo workspace (daemons/config-broker) -> its own target
# dir in the persistent cache. Pure Rust, no C/C++.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-config-broker"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$CARGO_TARGET_DIR"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the config broker (arlen-config-broker) - Debian-native ($(cargo --version))"
cargo build --release --manifest-path daemons/config-broker/Cargo.toml

# Its system unit's ExecStart is /usr/lib/arlen/libexec/arlen-config-broker. The
# broker only authenticates callers by uid (SO_PEERPIDFD) + the admitted-writer
# app-id gate; it does not itself need to resolve from a canonical path, but it
# lives beside the other libexec daemons for consistency.
install -Dm755 "$CARGO_TARGET_DIR/release/arlen-config-broker" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-config-broker"
echo ">> staged arlen-config-broker into the image"
