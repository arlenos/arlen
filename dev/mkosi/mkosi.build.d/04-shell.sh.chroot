#!/bin/sh
# Phase 4 of the Debian-native build (CHROOT): the desktop shell
# (arlen-desktop-shell, a Tauri 2 app) - ranked hard part, it runs the SvelteKit
# frontend in WebKitGTK, which must paint under software GL (llvmpipe) on the VM.
# Two-step like `cargo tauri build`: build the frontend (vite -> ../build, the
# tauri frontendDist) then the Tauri Rust backend (links WebKitGTK/GTK/soup,
# embeds the frontend). rustup was installed by phase 2; node 20 + the -dev libs
# by phase 1. Network (npm registry + cargo) is on via WithNetwork=yes.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-shell"   # separate workspace from the daemons
export CXXFLAGS="-include cstdint"
export LIBGL_ALWAYS_SOFTWARE=1                   # llvmpipe, harmless at build time
export npm_config_cache="$cache/npm"            # persist the npm cache across builds
mkdir -p "$CARGO_TARGET_DIR" "$npm_config_cache"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen/apps/desktop-shell"
echo ">> npm ci (frontend + tauri-cli deps)"
npm ci
# Build via the tauri CLI in PRODUCTION mode (not a plain `cargo build`, which
# leaves the webview pointed at devUrl http://localhost:1420 -> connection
# refused). `tauri build` runs the beforeBuildCommand (vite -> ../build) then a
# release cargo build whose webview loads the embedded ../build assets.
# --no-bundle: we only want the binary, not a .deb/AppImage.
echo ">> tauri build --no-bundle (production) arlen-desktop-shell"
./node_modules/.bin/tauri build --no-bundle

out=$(find "$CARGO_TARGET_DIR" -type f -path '*/release/arlen-desktop-shell' 2>/dev/null \
        | head -1)
[ -n "$out" ] || { echo "!! arlen-desktop-shell not found after build" >&2; exit 1; }
install -Dm755 "$out" "$DESTDIR/usr/bin/arlen-desktop-shell"
echo ">> staged arlen-desktop-shell into the image"
