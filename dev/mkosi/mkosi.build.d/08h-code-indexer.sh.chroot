#!/bin/sh
# Phase 8h (CHROOT): the code indexer (arlen-code-indexer), a Tier-2 KG producer
# that tree-sits source files and emits code-symbol nodes/edges into the knowledge
# graph. Built + intended as an always-on user service (Type=notify,
# WantedBy=default.target) but never wired into the image - the "built, not
# deployed" class. A deployed arlen should run its KG producers, so it is packaged
# like the other libexec daemons. (In the minimal image /home/arlen/work is empty
# at boot, so it starts and finds nothing to index until real code is present;
# that is expected, the daemon is correct for a populated system.)
#
# Resolves as a standalone package (cargo build --manifest-path) -> its own target
# dir in the persistent cache. Pure Rust, no C/C++ beyond the tree-sitter crates'
# vendored grammars.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-code-indexer"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$CARGO_TARGET_DIR"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the code indexer (arlen-code-indexer) - Debian-native ($(cargo --version))"
cargo build --release --manifest-path daemons/code-indexer/Cargo.toml

install -Dm755 "$CARGO_TARGET_DIR/release/arlen-code-indexer" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-code-indexer"
echo ">> staged arlen-code-indexer into the image"
