#!/bin/sh
# Phase 5 of the Debian-native build (CHROOT): the AI layer - the pi-backed
# engine daemon (arlen-ai-engine-daemon) + the egress proxy (arlen-ai-proxy), so
# the in-VM dogfood can drive the real KG-AI loop (file.opened -> KG -> the
# curator's capability-scoped read -> answer, then the gate/approve/undo flow).
# The engine daemon is the pi-agent-adoption drop-in for the retired native
# ai-agent/ai-daemon (it owns org.arlen.AI1 + org.arlen.AIAgent1); the proxy is
# the egress authoriser that holds the provider->endpoint catalog + forwards to
# the inference engine (llama-server, a later phase).
#
# Unlike the knowledge daemon this needs NO C++/Kuzu and NO ONNX: the engine
# daemon builds on arlen-ai-core with the S17 injection classifier behind an
# off-by-default `onnx` feature, so the default build pulls neither ort nor a C++
# toolchain. CPU-only, software-GL-irrelevant. The engine daemon is its OWN cargo
# workspace (daemons/ai-engine-daemon/Cargo.toml); the proxy lives in the ai/
# workspace (ai/Cargo.toml). They build independently (they talk over D-Bus, no
# build dep), so each gets its own target dir in the persistent cache.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME"

# rustup stable was bootstrapped by phase 2 into the shared cache; bootstrap here
# too in case the phases run independently (idempotent, skip if present).
if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the AI layer (engine daemon + proxy) - Debian-native ($(cargo --version))"

# The proxy (ai/ workspace, its own target dir). The default feature set leaves
# the onnx classifier out, so this stays pure-Rust.
CARGO_TARGET_DIR="$cache/target-ai" \
    cargo build --release --manifest-path ai/Cargo.toml -p arlen-ai-proxy

# The pi-backed engine daemon (its own workspace + its own target dir).
CARGO_TARGET_DIR="$cache/target-ai-engine" \
    cargo build --release --manifest-path daemons/ai-engine-daemon/Cargo.toml

# Install under /usr/lib/arlen/libexec, NOT /usr/bin: this is the canonical path
# the security model resolves identity against - ai-proxy's CallerAllowlist
# exact-matches the libexec paths, and path_to_app_id maps them to the admitted
# app ids (auditd's ADMITTED). Notably arlen-ai-engine-daemon resolves to app id
# `ai-agent` (identity.rs: the drop-in curator role reuses the same principal), so
# its ai-agent.toml graph profile keys correctly. A /usr/bin install would make it
# unresolvable and fail the proxy's exact match.
install -Dm755 "$cache/target-ai/release/arlen-ai-proxy" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-ai-proxy"
echo ">> staged arlen-ai-proxy into the image (libexec, the canonical identity path)"
install -Dm755 "$cache/target-ai-engine/release/arlen-ai-engine-daemon" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-ai-engine-daemon"
echo ">> staged arlen-ai-engine-daemon into the image (libexec, the canonical identity path)"

# The curator discovers behaviours from /usr/share/arlen/agent/behaviours (the
# BuiltIn source, ai-skills/loader.rs); bake the shipped SKILL.md set there so
# auto-tag-by-project (+ the others) are loadable without ARLEN_AGENT_BEHAVIOURS.
behdest="$DESTDIR/usr/share/arlen/agent/behaviours"
mkdir -p "$behdest"
cp -r "$SRCDIR/arlen/ai/ai-skills/behaviours/." "$behdest/"
echo ">> baked the agent behaviours into the image"

# The pi runtime the engine daemon spawns as its sidecar (node >=22 + the pinned
# pi engine + the built pi-plugins extension) is vendored by phase 05b-pi into
# /usr/lib/arlen/{node-runtime,pi,pi-plugins}. Until an image is actually built
# and booted, that phase + this one are UNVERIFIED; if pi is absent the daemon
# boots INERT (the contract socket serves fail-closed, pi stays unspawned -
# fail-safe, not a boot failure).
