#!/bin/sh
# Phase 8f (CHROOT): the anomaly detector (arlen-anomalyd). It reads the audit
# ledger + the event bus and writes dispatched alerts to
# ~/.local/share/arlen/anomaly/alerts.json, which the harness Notices panel reads
# (apps/harness/src-tauri/src/notices.rs). Without it that file is never produced,
# so the shell/harness Notices surface is dead in the image - the same "backend
# built, not deployed" class as the consent broker. Packaged like the other
# libexec daemons.
#
# Its own standalone cargo workspace (daemons/anomaly-detector) -> its own target
# dir in the persistent cache. Pure Rust, no C/C++.
set -eu

cache="${BUILDDIR:-/var/tmp/arlen-build}"
export RUSTUP_HOME="$cache/rustup"
export CARGO_HOME="$cache/cargo-home"
export CARGO_TARGET_DIR="$cache/target-anomaly"
mkdir -p "$RUSTUP_HOME" "$CARGO_HOME" "$CARGO_TARGET_DIR"

if [ ! -x "$CARGO_HOME/bin/cargo" ]; then
    echo ">> bootstrapping rustup stable into the build cache"
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --no-modify-path --profile minimal --default-toolchain stable
fi
export PATH="$CARGO_HOME/bin:$PATH"

cd "$SRCDIR/arlen"   # the repo root, mounted via BuildSources=../../:arlen
echo ">> cargo build the anomaly detector (arlen-anomalyd) - Debian-native ($(cargo --version))"
cargo build --release --manifest-path daemons/anomaly-detector/Cargo.toml

install -Dm755 "$CARGO_TARGET_DIR/release/arlen-anomalyd" \
    "$DESTDIR/usr/lib/arlen/libexec/arlen-anomalyd"
echo ">> staged arlen-anomalyd into the image"
