    set -euo pipefail
    cargo build --manifest-path "{{ROOT}}/daemons/event-bus/Cargo.toml"
    cargo build --manifest-path "{{ROOT}}/daemons/knowledge/Cargo.toml"
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" \
        --test integration_backend_smoke -- --ignored

# Run the pi-gated tests against a vendored pi engine (v0.79.10, cloned at
# ARLEN_PI_INSTALL) and a node>=22 runtime (ARLEN_PI_NODE_RUNTIME): rebuilds the
# Arlen pi-plugins extension, then the confined-sidecar spawn test (pi actually
# starts node under bwrap) and the gate/audit/proxy end-to-end suite. Override the
# ARLEN_PI_* paths to relocate the install. Needs a userns-capable host + bwrap.
pi-e2e:
    #!/usr/bin/env bash
    set -euo pipefail
    export ARLEN_PI_NODE_RUNTIME="${ARLEN_PI_NODE_RUNTIME:-$HOME/.local/share/arlen-node22}"
    export ARLEN_PI_INSTALL="${ARLEN_PI_INSTALL:-$HOME/Repositories/pi}"
    export ARLEN_PI_EXTENSION="${ARLEN_PI_EXTENSION:-{{ROOT}}/ai/pi-plugins/dist/extension.js}"
    export PATH="$ARLEN_PI_NODE_RUNTIME/bin:$PATH"
    npm --prefix "{{ROOT}}/ai/pi-plugins" run build
    cargo test --manifest-path "{{ROOT}}/daemons/ai-engine-daemon/Cargo.toml" \
        --lib the_confined_node_starts -- --ignored
    cargo test --manifest-path "{{ROOT}}/daemons/ai-engine-daemon/Cargo.toml" \
        --test e2e_gate -- --ignored

# Dogfood Phase-1 data-path check (first-dogfoodable-session-plan.md): with the
# `just dev` backend ALREADY up, emit a file.opened on the LIVE bus, confirm it
# lands in the live event store, and probe the knowledge graph for the promoted
# File node - reporting the bus->KG ingest + the capability-scoped read per step
# (the read is RS-R1-gated for an unprofiled caller, by design). The AI-answer
# half (Ollama round-trip) is Tim's install + a human look.
dogfood-datapath:
    cargo run --quiet --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" --example dogfood_datapath

# Dogfood Phase-0 AI enable (first-dogfoodable-session-plan.md): the AI is DISABLED
# by default (the fail-closed posture), so the harness answers nothing until
# `[ai] enabled = true` is set; and the provider auto-defaults to ollama-default
# but the MODEL defaults to llama3:8b, so the plan's qwen2.5:7b must be pinned to
# match the `ollama pull`. This writes a starter ai.toml ONLY if absent (never
# clobbers an existing config). Pairs with: `ollama pull qwen2.5:7b`.
dogfood-ai-config:
    #!/usr/bin/env bash
    set -euo pipefail
    cfg="${XDG_CONFIG_HOME:-$HOME/.config}/arlen/ai.toml"
    if [ -f "$cfg" ]; then
      echo "ai.toml already exists at $cfg - not clobbering. Ensure it has:"
      echo '  [ai]'; echo '  enabled = true'; echo '  provider = "ollama-default"'
      echo '  [provider]'; echo '  model = "qwen2.5:7b"'
      exit 0
    fi
    mkdir -p "$(dirname "$cfg")"
    printf '[ai]\nenabled = true\nprovider = "ollama-default"\n\n[provider]\nmodel = "qwen2.5:7b"\n' > "$cfg"
    echo "wrote dogfood ai.toml -> $cfg (local Ollama enabled). Now: ollama pull qwen2.5:7b"

# Executor go-live PREP step P5 (executor-live-golive-plan.md): install the
# agent's permission profile to ~/.config/permissions/ai-agent.toml (honours
# XDG_CONFIG_HOME). It grants EXACTLY the one File -[FILE_PART_OF]-> Project link
# the deterministic auto-tag workflow writes, nothing else. This does NOT enable
# production: flipping `executor_live = true` in ai.toml is Tim's conscious step
# AFTER a green rehearsal (`just go-live-rehearsal`); this recipe only puts the
# grant in place so that flip is bounded.
provision-agent-profile:
    #!/usr/bin/env bash
    set -euo pipefail
    dest="${XDG_CONFIG_HOME:-$HOME/.config}/permissions"
    mkdir -p "$dest"
    install -m644 "{{ROOT}}/daemons/ai-engine-daemon/dist/permissions/ai-agent.toml" "$dest/ai-agent.toml"
    echo "installed agent permission profile -> $dest/ai-agent.toml"
    echo "NB executor_live stays OFF; flipping it in ai.toml is a separate manual step."

# Headless terminal round-trip smoke (#3 PR-2): build the prod-asset terminal
# binary (`cargo tauri build` embeds the frontend; a plain `cargo build` loads
# the dev URL and renders nothing), then drive a real command through the running
# app under tauri-driver + Xvfb + openbox and assert its output renders in the
# grid. Proves the whole input -> PTY -> shell -> grid/block path end-to-end
# (a frontend-only test cannot). Needs tauri-driver, WebKitWebDriver, Xvfb,
# openbox. The literal pixel screenshot is not checked (WebKitWebDriver renders
# offscreen under Xvfb); this asserts the rendered DOM content.
terminal-smoke:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{ROOT}}/apps/terminal" && cargo tauri build --debug --no-bundle
    SHOOT_EXEC='sleep 1; echo ARLEN_TERMINAL_SMOKE' SHOOT_EXPECT='ARLEN_TERMINAL_SMOKE' \
        "{{ROOT}}/dev/screenshot/shoot-app.sh" \
        "{{ROOT}}/target/debug/arlen-terminal" "" "" 12

# IT-1 nightly (integration-testing-plan.md §4 / coder-night-backlog-2 §4.3):
# build EVERY daemon the suite spawns (event-bus, knowledge, audit-daemon, the
# ai/ workspace for arlen-ai-proxy), run the WHOLE #[ignore]d backend suite
# single-threaded, and capture a timestamped report under the state dir. NB the
# four native-agent scenarios (workflow-audit, executor-write, undo, canary) now
# SKIP: they spawned the retired arlen-ai-agent binary and await a pi-engine-
# daemon rewrite. Exits
# with the run's status so a wrapping systemd user timer or cron reads pass/fail
# and a morning digest can parse the report. Each scenario owns a hermetic
# `EphemeralStack`, so teardown is automatic (no shared state to clean). Needs a
# FUSE-capable host for the timeline mount, by design. Debug builds, because the
# harness resolves spawned binaries from the shared `target/debug`.
integration-nightly:
    #!/usr/bin/env bash
    set -uo pipefail
    report_dir="${XDG_STATE_HOME:-$HOME/.local/state}/arlen/integration"
    mkdir -p "$report_dir"
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    report="$report_dir/it1-$stamp.log"
    echo "IT-1 nightly $stamp (host $(uname -n))" | tee "$report"
    for c in daemons/event-bus daemons/knowledge daemons/audit-daemon daemons/code-indexer ai; do
        echo "== build $c ==" | tee -a "$report"
        cargo build --manifest-path "{{ROOT}}/$c/Cargo.toml" 2>&1 | tee -a "$report"
    done
    echo "== run IT-1 (#[ignore]d, single-threaded) ==" | tee -a "$report"
    # Skip the live-executor go-live scenarios: they have their own `go-live-rehearsal`
    # recipe and are gated on the external-trigger gate decision (auto-tag is
    # file.opened-triggered -> RequireConfirmation -> the executor does not write, so
    # the undo scenario cannot pass yet). Including them here makes the nightly
    # permanently red and conflates "backend healthy" with "go-live still gated"; the
    # nightly is the backend-health signal, the rehearsal recipe is the go-live gate.
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" \
        --test integration_backend_smoke -- --ignored --test-threads=1 --skip the_live_executor 2>&1 | tee -a "$report"
    status="${PIPESTATUS[0]}"
    echo "== IT-1 nightly exit ${status} (report ${report}) ==" | tee -a "$report"
    exit "${status}"

# Executor go-live REHEARSAL (executor-live-golive-plan.md P6): build the daemon
# set and run ONLY the live-executor scenarios against a DISPOSABLE graph - write
# a FILE_PART_OF, prove op-id idempotency (re-emit -> still one edge), and undo it
# via compensate. Each scenario seeds its OWN ephemeral ai.toml with
# `executor_live = true`; production's `~/.config/arlen/ai.toml` is never touched.
# This is the green-light Tim watches BEFORE he flips production executor_live
# (his conscious step, not this recipe). Captures a timestamped report and exits
# with the run's status. FUSE-host-gated (the timeline mount) + the undo scenario
# needs `dbus-daemon` on PATH; scenarios self-skip when a binary is missing.
go-live-rehearsal:
    #!/usr/bin/env bash
    set -uo pipefail
    report_dir="${XDG_STATE_HOME:-$HOME/.local/state}/arlen/integration"
    mkdir -p "$report_dir"
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    report="$report_dir/golive-$stamp.log"
    echo "go-live rehearsal $stamp (host $(uname -n))" | tee "$report"
    for c in daemons/event-bus daemons/knowledge daemons/audit-daemon ai; do
        echo "== build $c ==" | tee -a "$report"
        cargo build --manifest-path "{{ROOT}}/$c/Cargo.toml" 2>&1 | tee -a "$report"
    done
    echo "== run the live-executor rehearsal (#[ignore]d, single-threaded) ==" | tee -a "$report"
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" \
        --test integration_backend_smoke -- --ignored --test-threads=1 the_live_executor 2>&1 | tee -a "$report"
    status="${PIPESTATUS[0]}"
    echo "== rehearsal exit ${status} (report ${report}) ==" | tee -a "$report"
    echo "NB a GREEN run does NOT flip production; executor_live in ~/.config/arlen/ai.toml stays Tim's manual step."
    exit "${status}"

