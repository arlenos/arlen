# Arlen task runner. Run from anywhere; paths resolve against the repo root.
#   just            list recipes
#   just dev        full daemon stack (process-compose)
#   just dev-ui harness   one Tauri app, fast UI loop
#   just check      local mirror of CI (all rust crates + frontend svelte-check)
# The compositor is a separate repo; point COMPOSITOR_PATH at it for `just compositor`.

ROOT := justfile_directory() / ".."
COMPOSITOR_PATH := env_var_or_default("COMPOSITOR_PATH", ROOT / "../compositor")

# lbug (Kuzu) vendors thrift C++ that misses <cstdint> on newer GCC.
export CXXFLAGS := "-include cstdint"

# The rust crates CI builds, in rough dependency order. Mirrors the CI matrix.
RUST_CRATES := "contracts/audit-proto contracts/notification-proto contracts/modulesd-proto contracts/ai-engine-contract contracts/graph-schema contracts/forage-recipe contracts/capsule contracts/artifact contracts/lenv sdk sdk/config-format sdk/i18n ai daemons/event-bus daemons/knowledge daemons/notification-daemon daemons/audit-daemon daemons/anomaly-detector daemons/modulesd daemons/installd daemons/knowledge-mcp daemons/file-manager-mcp daemons/system-monitor-mcp daemons/xdg-portal daemons/capsuled daemons/arlen-run daemons/online-accounts daemons/power-daemon daemons/journald-parser daemons/code-indexer daemons/print daemons/transfer-daemon daemons/lock-auth daemons/wallpaper daemons/integration-packages daemons/bridge-ingest daemons/consent-broker daemons/ai-engine-daemon forage forage/store forage/fetch forage/build forage/package forage/extract forage/pipeline forage/signing forage/patch forage/capabilities forage/cookbook-index forage/cookbook-sign forage/cookbook-resolve apps/terminal/core apps/terminal/engine apps/files/core apps/viewers/core apps/viewers/decode-image apps/viewers/decode-jxl apps/viewers/decode-heic apps/viewers/host apps/viewers/decode-audio dev/integration"

# The SvelteKit frontends CI svelte-checks.
FRONTENDS := "apps/settings apps/harness apps/desktop-shell apps/terminal apps/files apps/viewers apps/greeter sdk/ui-kit"

# List recipes (default).
default:
    @just --list

# One-time: install process-compose into ~/.local/bin (no sudo).
setup:
    #!/usr/bin/env bash
    set -euo pipefail
    if command -v process-compose >/dev/null 2>&1; then echo "process-compose already installed: $(command -v process-compose)"; exit 0; fi
    mkdir -p "$HOME/.local/bin"
    ver="v1.40.1"
    url="https://github.com/F1bonacc1/process-compose/releases/download/${ver}/process-compose_linux_amd64.tar.gz"
    echo "downloading process-compose ${ver}"
    tmp="$(mktemp -d)"
    curl -fsSL "$url" -o "$tmp/pc.tar.gz"
    tar -xzf "$tmp/pc.tar.gz" -C "$tmp"
    install -m755 "$tmp/process-compose" "$HOME/.local/bin/process-compose"
    rm -rf "$tmp"
    echo "installed to $HOME/.local/bin/process-compose (ensure ~/.local/bin is on PATH)"

# Full daemon stack via process-compose (TUI). `--profile shell` / `--profile portal`
# compose in the graphical overlays; other args pass through, e.g. -D for detached.
dev *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v process-compose >/dev/null 2>&1; then echo "process-compose missing; run 'just setup'" >&2; exit 1; fi
    # Export the resolved compositor path so process-compose can expand it in the
    # shell overlay. process-compose does NOT honour bash `${VAR:-default}` syntax
    # (it expands an unset var to empty), so the overlay references ${COMPOSITOR_PATH}
    # plainly and relies on this export instead of an in-command default.
    export COMPOSITOR_PATH="{{COMPOSITOR_PATH}}"
    dir="{{justfile_directory()}}"
    # The pinned process-compose (v1.40.1) has no --profile flag and ignores the
    # `profiles:` field, so translate `--profile <name>` into a composed overlay file.
    configs=(-f "$dir/process-compose.yaml")
    passthrough=()
    args=({{ARGS}})
    i=0
    while [ "$i" -lt "${#args[@]}" ]; do
      if [ "${args[$i]}" = "--profile" ]; then
        i=$((i + 1))
        name="${args[$i]:-}"
        overlay="$dir/process-compose.$name.yaml"
        if [ ! -f "$overlay" ]; then echo "unknown profile '$name' (no $overlay)" >&2; exit 1; fi
        configs+=(-f "$overlay")
      else
        passthrough+=("${args[$i]}")
      fi
      i=$((i + 1))
    done
    # process-compose's TUI (tview/tcell) panics with "close of nil channel" when
    # there is no interactive terminal to initialise a screen - so an agent / CI /
    # piped run (no TTY on stdout) crashes before the stack comes up, while Tim's
    # interactive run is fine. Detect the no-TTY case and drive it headless there
    # (logs stream to stdout, greppable); an interactive run keeps the TUI. This is
    # what makes `just dev` launch reliably regardless of environment. A caller who
    # passes their own `-t`/`--tui` wins (we do not override it).
    tui=()
    if [ ! -t 1 ] && ! printf '%s\n' ${passthrough[@]+"${passthrough[@]}"} | grep -qE -- '^(-t|--tui)'; then
      tui=(-t=false)
    fi
    # -U: serve over a per-pid unix socket instead of TCP :8080, so the dev stack
    # never collides with whatever else holds 8080 on the machine.
    cd "{{ROOT}}" && process-compose "${configs[@]}" -U ${tui[@]+"${tui[@]}"} up ${passthrough[@]+"${passthrough[@]}"}

# Build the sandboxed thumbnail worker the files app spawns for its grid
# thumbnails (ai-sandbox `thumbnail` feature).
thumbnail-worker:
    cargo build --manifest-path "{{ROOT}}/ai/Cargo.toml" -p arlen-ai-sandbox --features thumbnail --bin arlen-thumbnail-sandbox

# Quick loop: one Tauri app via cargo tauri dev (needs a running compositor).
# The files app additionally gets the freshly built thumbnail worker via
# ARLEN_THUMBNAIL_SANDBOX_BIN (the installed libexec path does not exist in dev).
dev-ui app:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{app}}" = "files" ]; then
        just thumbnail-worker
        export ARLEN_THUMBNAIL_SANDBOX_BIN="{{ROOT}}/ai/target/debug/arlen-thumbnail-sandbox"
    fi
    cd "{{ROOT}}/apps/{{app}}" && cargo tauri dev

# Register the Arlen Viewer as the default xdg handler for image + audio MIMEs
# (so they open in the viewer, not the browser). NB ~/.config/mimeapps.list is
# USER-GLOBAL: this affects every desktop session until reverted, so the register
# backs the list up first. Revert with `just viewer-unset-default`.
viewer-set-default:
    cargo build --manifest-path "{{ROOT}}/apps/viewers/src-tauri/Cargo.toml"
    "{{ROOT}}/apps/viewers/src-tauri/target/debug/arlen-viewers" --register-default-handler

# Revert `viewer-set-default`: restore the backed-up mimeapps.list and drop the
# viewer's .desktop entry.
viewer-unset-default:
    "{{ROOT}}/apps/viewers/src-tauri/target/debug/arlen-viewers" --unregister-default-handler

# eBPF kernel-layer in QEMU (off-host, by design).
vm:
    bash "{{justfile_directory()}}/vm/dev.sh" run

# Build one crate (e.g. `just build daemons/knowledge`) or all in order.
build crate="":
    #!/usr/bin/env bash
    set -euo pipefail
    if [ -n "{{crate}}" ]; then cargo build --manifest-path "{{ROOT}}/{{crate}}/Cargo.toml"; exit 0; fi
    for c in {{RUST_CRATES}}; do echo "== build $c =="; cargo build --manifest-path "{{ROOT}}/$c/Cargo.toml"; done

# Test one crate or the whole matrix. nextest gives process-per-test isolation +
# parallel scheduling + cleaner output; doctests run separately since nextest does
# not execute them; the installd workspace and knowledge daemon keep serial
# execution for their shared-state tests, matching the CI per-path rule.
test crate="":
    #!/usr/bin/env bash
    set -euo pipefail
    run_one() {
        local c="$1" extra=""
        case "$c" in
            daemons/installd|daemons/knowledge) extra="--test-threads=1" ;;
        esac
        cargo nextest run --manifest-path "{{ROOT}}/$c/Cargo.toml" $extra
        cargo test --doc --manifest-path "{{ROOT}}/$c/Cargo.toml"
    }
    if [ -n "{{crate}}" ]; then run_one "{{crate}}"; exit 0; fi
    for c in {{RUST_CRATES}}; do echo "== test $c =="; run_one "$c"; done

# Cheap local mirror of CI: cargo check every rust crate + svelte-check + vitest every frontend.
check:
    #!/usr/bin/env bash
    set -euo pipefail
    for c in {{RUST_CRATES}}; do echo "== check $c =="; cargo check --manifest-path "{{ROOT}}/$c/Cargo.toml"; done
    for f in {{FRONTENDS}}; do
        echo "== svelte-check $f =="; (cd "{{ROOT}}/$f" && npx svelte-check --threshold error)
        if [ "$(cd "{{ROOT}}/$f" && npm pkg get scripts.test)" != "{}" ]; then
            echo "== vitest $f =="; (cd "{{ROOT}}/$f" && npm test -- --passWithNoTests)
        fi
    done

# Clippy, warnings as errors, across all rust crates.
lint:
    #!/usr/bin/env bash
    set -euo pipefail
    for c in {{RUST_CRATES}}; do echo "== clippy $c =="; cargo clippy --manifest-path "{{ROOT}}/$c/Cargo.toml" --all-targets -- -D warnings; done

# Format all rust crates.
fmt:
    #!/usr/bin/env bash
    set -euo pipefail
    for c in {{RUST_CRATES}}; do cargo fmt --manifest-path "{{ROOT}}/$c/Cargo.toml" --all; done

# License hygiene: cargo-deny allowlist over every workspace + REUSE/SPDX lint.
lint-licenses:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{ROOT}}"
    # This repo has no single root workspace, so each `[workspace]` root is checked
    # against the one root deny.toml via --config (discovered, so a new workspace is
    # covered automatically). Needs cargo-deny + reuse installed (CI installs them).
    roots=$(grep -rl '^\[workspace\]' --include=Cargo.toml . | grep -v '/target/' | xargs -n1 dirname | sort -u)
    for ws in $roots; do
        echo "== cargo-deny licenses: $ws =="
        cargo deny --manifest-path "$ws/Cargo.toml" --config "{{ROOT}}/deny.toml" check licenses
    done
    # `reuse lint` is advisory until the per-file SPDX headers + REUSE.toml land
    # (they wait on the copyright-holder decision); drop the `|| true` to gate it then.
    echo "== reuse lint (advisory until SPDX headers land) =="
    reuse lint || echo "reuse lint advisory: per-file SPDX headers + REUSE.toml pending the copyright-holder decision"

# Generate the THIRD-PARTY-NOTICES dependency-license artifact (gitignored).
notices:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{ROOT}}"
    # Bundle every dependency's license per workspace into THIRD-PARTY-NOTICES/ (a
    # build/release artifact, not committed). Needs `cargo-bundle-licenses` installed.
    outdir="THIRD-PARTY-NOTICES"
    rm -rf "$outdir"; mkdir -p "$outdir"
    roots=$(grep -rl '^\[workspace\]' --include=Cargo.toml . | grep -v '/target/' | xargs -n1 dirname | sort -u)
    for ws in $roots; do
        slug=$(echo "${ws#./}" | tr '/' '-')
        echo "== notices: $ws =="
        cargo bundle-licenses --manifest-path "$ws/Cargo.toml" --format yaml --output "$outdir/$slug.yaml"
    done

# The cross-daemon integration tests (the non-ignored, no-binary ones: the
# harness's own unit tests). The scenario tests that need built daemons are
# #[ignore]d; run them via `just integration-smoke`.
integration:
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml"

# IT-1 host-only backend smoke (integration-testing-plan.md §4): build the
# backend daemons, then run the hermetic #[ignore]d backend scenarios
# (`EphemeralStack`: stack-comes-up + the file.opened -> SQLite data-flow). Fast
# enough for the coder to run after a change as a "did I break a boundary" check.
integration-smoke:
    #!/usr/bin/env bash
    set -euo pipefail
    cargo build --manifest-path "{{ROOT}}/daemons/event-bus/Cargo.toml"
    cargo build --manifest-path "{{ROOT}}/daemons/knowledge/Cargo.toml"
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" \
        --test integration_backend_smoke -- --ignored

# Executor go-live PREP step P5 (executor-live-golive-plan.md): install the
# agent's permission profile to ~/.config/permissions/ai-agent.toml (honours
# XDG_CONFIG_HOME). It grants EXACTLY the one File -[FILE_PART_OF]-> Project link
# the deterministic auto-tag workflow writes, nothing else. This does NOT enable
# production: flipping `executor_live = true` in ai.toml is Tim's conscious step
# AFTER a green rehearsal (`just go-live-rehearsal`); this recipe only puts the
# grant in place so that flip is bounded.
provision-agent-profile:
    #!/usr/bin/env bash
    set -euo pipefail
    dest="${XDG_CONFIG_HOME:-$HOME/.config}/permissions"
    mkdir -p "$dest"
    install -m644 "{{ROOT}}/ai/ai-agent/dist/permissions/ai-agent.toml" "$dest/ai-agent.toml"
    echo "installed agent permission profile -> $dest/ai-agent.toml"
    echo "NB executor_live stays OFF; flipping it in ai.toml is a separate manual step."

# Headless terminal round-trip smoke (#3 PR-2): build the prod-asset terminal
# binary (`cargo tauri build` embeds the frontend; a plain `cargo build` loads
# the dev URL and renders nothing), then drive a real command through the running
# app under tauri-driver + Xvfb + openbox and assert its output renders in the
# grid. Proves the whole input -> PTY -> shell -> grid/block path end-to-end
# (a frontend-only test cannot). Needs tauri-driver, WebKitWebDriver, Xvfb,
# openbox. The literal pixel screenshot is not checked (WebKitWebDriver renders
# offscreen under Xvfb); this asserts the rendered DOM content.
terminal-smoke:
    #!/usr/bin/env bash
    set -euo pipefail
    cd "{{ROOT}}/apps/terminal" && cargo tauri build --debug --no-bundle
    SHOOT_EXEC='sleep 1; echo ARLEN_TERMINAL_SMOKE' SHOOT_EXPECT='ARLEN_TERMINAL_SMOKE' \
        "{{ROOT}}/dev/screenshot/shoot-app.sh" \
        "{{ROOT}}/apps/terminal/src-tauri/target/debug/arlen-terminal" "" "" 12

# IT-1 nightly (integration-testing-plan.md §4 / coder-night-backlog-2 §4.3):
# build EVERY daemon the suite spawns (event-bus, knowledge, audit-daemon and
# the ai-agent in the ai/ workspace), run the WHOLE #[ignore]d backend suite
# single-threaded, and capture a timestamped report under the state dir. Exits
# with the run's status so a wrapping systemd user timer or cron reads pass/fail
# and a morning digest can parse the report. Each scenario owns a hermetic
# `EphemeralStack`, so teardown is automatic (no shared state to clean). Needs a
# FUSE-capable host for the timeline mount, by design. Debug builds, because the
# harness resolves spawned binaries from each crate's `target/debug`.
integration-nightly:
    #!/usr/bin/env bash
    set -uo pipefail
    report_dir="${XDG_STATE_HOME:-$HOME/.local/state}/arlen/integration"
    mkdir -p "$report_dir"
    stamp="$(date -u +%Y%m%dT%H%M%SZ)"
    report="$report_dir/it1-$stamp.log"
    echo "IT-1 nightly $stamp (host $(uname -n))" | tee "$report"
    for c in daemons/event-bus daemons/knowledge daemons/audit-daemon ai; do
        echo "== build $c ==" | tee -a "$report"
        cargo build --manifest-path "{{ROOT}}/$c/Cargo.toml" 2>&1 | tee -a "$report"
    done
    echo "== run IT-1 (#[ignore]d, single-threaded) ==" | tee -a "$report"
    cargo test --manifest-path "{{justfile_directory()}}/integration/Cargo.toml" \
        --test integration_backend_smoke -- --ignored --test-threads=1 2>&1 | tee -a "$report"
    status="${PIPESTATUS[0]}"
    echo "== IT-1 nightly exit ${status} (report ${report}) ==" | tee -a "$report"
    exit "${status}"

# Born-translatable gate (i18n-plan.md I18N-R2): fail on a hardcoded user-facing
# string in the Svelte frontends that is not in the committed baseline. Advisory
# today (run on demand / pre-commit); the blocking CI gate is flipped on once the
# UI stabilises. Re-snapshot with `just i18n-baseline` after intentional changes.
i18n-lint:
    cd "{{ROOT}}" && cargo run -q --manifest-path sdk/i18n/Cargo.toml --bin arlen-i18n-lint -- --root apps --baseline dev/i18n-baseline.tsv

# Re-snapshot the born-translatable baseline (accept the current hardcoded set).
i18n-baseline:
    cd "{{ROOT}}" && cargo run -q --manifest-path sdk/i18n/Cargo.toml --bin arlen-i18n-lint -- --root apps --baseline dev/i18n-baseline.tsv --update

# Born-RTL gate (I18N-R3): fail on NEW physical directional CSS, accept the existing
# via the baseline. Like i18n-lint, run on demand today; the blocking CI gate flips
# on once the UI stabilises. Re-snapshot with `just rtl-baseline` after intentional changes.
rtl-lint:
    cd "{{ROOT}}" && cargo run -q --manifest-path sdk/i18n/Cargo.toml --bin arlen-rtl-lint -- --root apps --root sdk/ui-kit --baseline dev/rtl-baseline.tsv

# Re-snapshot the born-RTL baseline (accept the current physical directional CSS).
rtl-baseline:
    cd "{{ROOT}}" && cargo run -q --manifest-path sdk/i18n/Cargo.toml --bin arlen-rtl-lint -- --root apps --root sdk/ui-kit --baseline dev/rtl-baseline.tsv --update

# Compositor nested in the current Wayland session (separate repo).
# DISPLAY="" forces the Winit/Wayland backend so wlr-layer-shell is advertised.
compositor:
    cd "{{COMPOSITOR_PATH}}" && DISPLAY="" WAYLAND_DISPLAY=wayland-1 cargo run --bin cosmic-comp

