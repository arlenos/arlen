[Unit]
Description=Arlen Install Daemon (user service)
Documentation=https://github.com/arlenos/installd

[Service]
Type=dbus
BusName=org.arlen.InstallDaemon1
ExecStart=%h/.local/lib/arlen/libexec/arlen-installd

# Security hardening.
ProtectSystem=strict
ReadWritePaths=%h/.local/share/arlen %h/.local/share/applications
PrivateTmp=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes

[Install]
WantedBy=default.target
