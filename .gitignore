
# Rust build artifacts. No leading slash, so it matches the target/ dir of every
# crate AND of every nested standalone-workspace crate (contracts/*, daemons/*,
# forage/*), not only a root-level target/.
target/

# Architecture specs live in the private arlenos/arlen-docs repo, cloned here for local use.
docs/

# Local build logs
logs/

# Generated third-party license notices (a build/release artifact from
# `just notices`; CI uploads it rather than committing it).
THIRD-PARTY-NOTICES/

# Local-only working context for Claude Code (never committed).
CLAUDE.md

# Screenshots may contain private content; never committed
dev/screenshot/out/

# Stray verification screenshots dropped at the repo root (terminal/UI compares).
# Root-anchored so the tracked app icons under apps/*/icons/ are unaffected.
/*.png

# Playwright MCP session artifacts (console logs, snapshots) from local UI checks
.playwright-mcp/

# transient build/verify logs
dev/mkosi/buildimg-new.log
dev/vm/verify-run.log
dev/mkosi/buildimg*.log
