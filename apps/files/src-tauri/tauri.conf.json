{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arlen-files",
  "version": "0.1.0",
  "identifier": "dev.arlen.files",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1427",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Files",
        "width": 1100,
        "height": 700,
        "minWidth": 760,
        "minHeight": 480,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
