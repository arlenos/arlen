# Arlen curated zsh (TM-R2): delightful by default, uncrippling by rule
# (terminal.md §3).
#
# The default plugin set is resolved, ordered and .zwc-compiled at IMAGE BUILD
# (see README.md), so the user's first shell start is already warm; antidote
# stays present only for a user who ADDS plugins. A default-plugin update ships
# with an OS update, not a `git pull` - the curated-OS direction. A power user's
# own ~/.zshrc replaces this file entirely; the curated set is the default for
# the spectrum, not a cage.
#
# Every tool init is guarded by `command -v`, so a missing component degrades to
# a plain (but working) shell rather than an error on startup.

# The VT engine exports TERM; default it for a bare login without the engine.
export TERM=${TERM:-xterm-256color}

# The curated plugin bundle, statically generated + .zwc-compiled at image build
# (antidote: `antidote bundle < zsh_plugins.txt > bundle.zsh && zcompile bundle.zsh`).
# Source the warm compiled bundle when present; otherwise let antidote resolve the
# list live (a dev tree, or a user who edited the list). Skip silently if neither
# is available.
: ${ARLEN_ZSH_DIR:=/usr/share/arlen/zsh}
if [[ -r $ARLEN_ZSH_DIR/bundle.zsh ]]; then
  source $ARLEN_ZSH_DIR/bundle.zsh
elif command -v antidote >/dev/null 2>&1 && [[ -r $ARLEN_ZSH_DIR/zsh_plugins.txt ]]; then
  source <(antidote bundle < $ARLEN_ZSH_DIR/zsh_plugins.txt)
fi

# Prompt: starship (Rust, cross-shell, TOML-configured), over powerlevel10k.
# Point it at the curated Arlen config (flat, muted palette) when it ships, so
# the out-of-box prompt is Arlen-styled rather than starship's generic default;
# a user's own STARSHIP_CONFIG set above wins.
[[ -r $ARLEN_ZSH_DIR/starship.toml ]] && : ${STARSHIP_CONFIG:=$ARLEN_ZSH_DIR/starship.toml} && export STARSHIP_CONFIG
command -v starship >/dev/null 2>&1 && eval "$(starship init zsh)"

# Directory jumping (zoxide) + fuzzy finding (fzf), wired together.
command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
command -v fzf    >/dev/null 2>&1 && eval "$(fzf --zsh 2>/dev/null)"

# Modern coreutils, INTERACTIVE-ONLY. The `[[ -o interactive ]]` guard keeps
# `#!/bin/sh` scripts and $(...) command substitutions on the unmodified GNU
# binaries. Honest narrowing: the guard fires per interactive INVOCATION, so an
# interactive `eza | head` still gets eza - the "scripts are safe" guarantee does
# not extend to interactive pipelines, stated not papered over.
if [[ -o interactive ]]; then
  command -v eza >/dev/null 2>&1 && {
    alias ls='eza --group-directories-first'
    alias ll='eza -lah --group-directories-first'
    alias tree='eza --tree'
  }
  command -v bat >/dev/null 2>&1 && alias cat='bat --paging=never --style=plain'
  command -v rg  >/dev/null 2>&1 && alias grep='rg'
  command -v fd  >/dev/null 2>&1 && alias find='fd'
fi

# Arlen terminal block marks (TM-R3): emit the OSC 133/633/7 marks the VT engine
# frames into command blocks. A no-op outside the Arlen engine (it returns early
# when $ARLEN_TERM_NONCE is unset), so this is safe in any zsh.
[[ -r $ARLEN_ZSH_DIR/arlen-shell-integration.zsh ]] \
  && source $ARLEN_ZSH_DIR/arlen-shell-integration.zsh
