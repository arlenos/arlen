# @xterm/addon-canvas@0.7.0 (the latest, used as the WebGL-fallback renderer)
# still declares peer @xterm/xterm@^5, but the app runs on @xterm/xterm@6. The
# addon is compatible at runtime; this accepts the lagging peer range so npm ci
# resolves instead of erroring on ERESOLVE.
legacy-peer-deps=true
