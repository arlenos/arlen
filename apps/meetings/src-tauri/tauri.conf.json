{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arlen-meetings",
  "version": "0.1.0",
  "identifier": "dev.arlen.meetings",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1432",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Meetings",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
